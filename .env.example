# Flask Environment Configuration
FLASK_ENV=development

# App secret key for session signing
SECRET_KEY=stock-manager-secret-key-12345

# PostgreSQL Database Connection String
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_manager

# Email alert notification configurations (optional)
MAIL_USERNAME=mock-email@gmail.com
MAIL_PASSWORD=mock-password
